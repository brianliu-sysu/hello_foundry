# 部署脚本使用的助记词（12/24 个英文单词，空格分隔）
# BaseScript 会从此助记词派生第 0 个账户（m/44'/60'/0'/0/0）作为部署地址
# 将本文件复制为 .env 并填入真实值后再部署：
#   cp .env.example .env
MNEMONIC="test test test test test test test test test test test junk"

# Etherscan API Key（用于 forge verify 时自动验证合约源码）
# 在 https://sepolia.etherscan.io/ 注册后获取
SEPOLIA_ETHERSCAN_API_KEY="CNGIR49GRI8M8FR74IU9KB4NCS529CRZB3"
