# RPC endpoint (required)
RPC_URL=http://127.0.0.1:8545

# FlashArbitrage contract address (required)
FLASH_ARBITRAGE_ADDRESS=0xYourFlashArbitrageAddress

# Uniswap V2 Factory address (required)
FACTORY_ADDRESS=0xYourFactoryAddress

# WETH address (required — WETH9 on Sepolia, or your local deployment)
WETH_ADDRESS=0xYourWETHAddress

# Bot wallet mnemonic phrase (required — must be the owner of FlashArbitrage)
# Derives the first account at path m/44'/60'/0'/0/0 (same as MetaMask / BaseScript)
MNEMONIC="your twelve word mnemonic phrase here"

# Polling interval in milliseconds (default: 2000)
POLL_INTERVAL_MS=2000

# Minimum profit in USD (18 decimals, default: 0.001 ETH worth)
MIN_PROFIT_USD=1000000000000000

# Gas price buffer multiplier (default: 1.2)
GAS_PRICE_BUFFER=1.2

# Max gas limit for arbitrage tx (default: 500000)
GAS_LIMIT=500000

# Comma-separated token addresses to monitor (at least 3 for triangular arbitrage)
# Example: 0xTokenA,0xTokenB,0xTokenC
MONITORED_TOKENS=

# Borrow amount per attempt in wei (default: 0.1 ETH equivalent)
BORROW_AMOUNT=100000000000000000

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
